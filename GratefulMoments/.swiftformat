--exclude Pods
--exclude Carthage
--exclude .build
--exclude DerivedData
--exclude *.xcodeproj
--exclude *.xcworkspace

--swift-version 6.2

--indent 4
--tabwidth 4
--maxwidth 120
--linebreaks lf
--semicolons never
--commas always
--trimwhitespace always
--stripunusedargs closure-only
--self remove
--ifdef no-indent
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapconditions before-first
--closingparen same-line
--callsiteparen balanced
--funcattributes prev-line
--typeattributes prev-line
--varattributes prev-line
--guardelse next-line
--elseposition same-line
--patternlet inline
--shortoptionals except-properties
--ranges no-space
--operatorfunc spaced
--emptybraces spaced
--hexgrouping 4,8
--decimalgrouping 3,6
--binarygrouping 4,8
--octalgrouping 4,8
--fractiongrouping disabled
--exponentgrouping disabled
--commas inline
--ranges spaced
--header ignore
